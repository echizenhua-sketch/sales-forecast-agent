# 产销预测智能工作台 - 环境配置示例
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME=产销预测智能工作台
API_PREFIX=/api

# MySQL 数据库配置（10.10.9.104 的 mysql8 容器，宿主机端口 11123）
DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@10.10.9.104:11123/supply_demand_forecast?charset=utf8mb4

# 文件上传配置
DATA_DIR=data
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# 会话配置
SECRET_KEY=change-me-in-production
SESSION_COOKIE_NAME=forecast_agent_session
SESSION_EXPIRE_HOURS=24

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=./logs

# AI 模型配置
# 使用兼容 Anthropic Messages API 的模型网关，例如 http://10.10.9.104:8080
AI_API_BASE=http://YOUR_MODEL_GATEWAY
AI_API_KEY=YOUR_MODEL_API_KEY
AI_MODEL=MiniMax-M3

# 长期记忆配置
# 使用项目内 JSONL 文件保存记忆，并通过 OpenAI-compatible embeddings 做向量检索。
MEMORY_ENABLED=false
MEMORY_BACKEND=vector_jsonl
MEMORY_DIR=.runtime/mem0
MEMORY_SEARCH_LIMIT=5
EMBEDDING_API_BASE=https://api-inference.modelscope.cn/v1
EMBEDDING_API_KEY=YOUR_EMBEDDING_API_KEY
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_ENCODING_FORMAT=float
EMBEDDING_TIMEOUT_SECONDS=30
